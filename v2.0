  sprite.fillSprite(TFT_BLACK);
  drawGradientBG(sprite);

  sprite.setTextDatum(TL_DATUM);
  sprite.setTextColor(C_YELLOW, S_BG);
  sprite.drawString("F1 STANDINGS", 10, 10, 2);

  sprite.drawFastHLine(0,35,320,C_PURPLE);

  sprite.setTextColor(C_WHITE,S_BG);

  for(int i=0;i<5;i++){
    String row = String(i+1) + ". " + f1Driver[i];
    sprite.drawString(row,20,55+(i*30),2);
    sprite.drawRightString(String(f1Points[i]),300,55+(i*30),2);
  }

  drawNavDots(sprite,3);
  sprite.pushSprite(0,0);
}

