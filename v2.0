} 


void fetchF1Standings() {

  Serial.println("Refreshing F1 standings...");

  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.begin("https://api.jolpi.ca/ergast/f1/current/driverStandings.json");

  int code = http.GET();

  if (code == 200) {

    DynamicJsonDocument doc(25000);
    deserializeJson(doc, http.getString());

    JsonArray standings =
      doc["MRData"]["StandingsTable"]["StandingsLists"][0]["DriverStandings"];

    for (int i = 0; i < 5; i++) {
      f1Driver[i] = standings[i]["Driver"]["familyName"].as<String>();
      f1Points[i] = standings[i]["points"].as<int>();
    }
  }

  http.end();
}

// ── Setup ─────────────────────────────────────
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("Loop running");
  pinMode(21, INPUT_PULLUP);
  

  tft.init();
  tft.setRotation(3);
   tft.invertDisplay(false);
  tft.fillScreen(BG);
  initColors();

  sprite.setColorDepth(16);
  sprite.createSprite(320, 240);

  showSplash("Connecting to WiFi...", ssid);
  WiFi.begin(ssid, password);
  int a=0;
  while(WiFi.status()!=WL_CONNECTED && a<30){delay(500);a++;}

  if(WiFi.status()==WL_CONNECTED){
    showSplash("Syncing NTP time...","pool.ntp.org");
    configTime(gmtOffset_sec,daylightOffset,ntpServer);
    struct tm ti; int tr=0;
    while(!getLocalTime(&ti)&&tr<20){delay(500);tr++;}
    showSplash("Fetching weather...","Thrissur, Kerala");
    fetchWeather();
    fetchF1Standings();
    lastWeatherFetch=millis();
  } else {
    showSplash("WiFi Failed!","Check credentials");
    delay(3000);
  }

  tft.fillScreen(BG);

}
// ── Loop ──────────────────────────────────────
void loop() {
  struct tm t;
  if(!getLocalTime(&t)){delay(50);return;}

 // Button on IO21 — press to switch screen
  static bool lastBtnState = HIGH;
  bool btnState = digitalRead(21);
  
  if(btnState == LOW && lastBtnState == HIGH){
    unsigned long now = millis();
    if(now - lastTouch > TOUCH_DEBOUNCE){
      lastTouch = now;
      currentScreen = (currentScreen + 1) % 5;

      sprite.fillSprite(TFT_BLACK);
      tft.fillScreen(TFT_BLACK);
      Serial.printf("Button! screen=%d\n", currentScreen);
    }
  }
  lastBtnState = btnState;
  if(millis() - lastF1Fetch > F1_REFRESH_INTERVAL){
    lastF1Fetch = millis();
    fetchF1Standings();
  }

  // Weather refresh
  

 switch(currentScreen){

  case 0:
    drawClock(t);
    break;

  case 1:
    drawFootball(t);
    break;

  case 2:
    drawF1Live(t);
    break;

  case 3:
    drawF1Standings(t);
    break;

  case 4:
    drawSportsNews(t);
    break;
}

  delay(50);
}
