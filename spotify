// ── Parse LRC timestamp ───────────────────────
// Format: [mm:ss.xx]
int parseLrcTime(String ts) {
  // ts like "01:23.45"
  int colon = ts.indexOf(':');
  int dot   = ts.indexOf('.');
  if(colon < 0) return 0;
  int mins = ts.substring(0, colon).toInt();
  int secs = ts.substring(colon+1, dot > 0 ? dot : ts.length()).toInt();
  int ms   = dot > 0 ? ts.substring(dot+1).toInt() * 10 : 0;
  return (mins * 60 + secs) * 1000 + ms;
}

// ── Fetch Lyrics from lrclib.net ──────────────
void fetchLyrics(String track, String artist) {
  if(track == prevTrackForLyrics) return;
  prevTrackForLyrics = track;
  lyricCount   = 0;
  currentLyric = 0;

  if(WiFi.status() != WL_CONNECTED) return;

  // URL encode basic
  track.replace(" ", "%20");
  artist.replace(" ", "%20");

  HTTPClient http;
  String url = "https://lrclib.net/api/get?track_name=" + track +
               "&artist_name=" + artist;
  http.begin(url);
  http.addHeader("User-Agent", "ESP32DeskClock/1.0");
  int code = http.GET();

  if(code == 200) {
    DynamicJsonDocument doc(8192);
    DeserializationError err = deserializeJson(doc, http.getString());
    if(!err && doc.containsKey("syncedLyrics")) {
      String lrc = doc["syncedLyrics"].as<String>();
      // Parse LRC lines
      int pos = 0;
      while(pos < lrc.length() && lyricCount < MAX_LYRICS) {
        int nl = lrc.indexOf('\n', pos);
        if(nl < 0) nl = lrc.length();
        String line = lrc.substring(pos, nl);
        line.trim();

        // Find timestamp [mm:ss.xx]
        if(line.startsWith("[")) {
          int close = line.indexOf(']');
          if(close > 0) {
            String ts   = line.substring(1, close);
            String text = line.substring(close + 1);
            text.trim();
            // Skip lines with no text or metadata
            if(text.length() > 0 && !ts.startsWith("ti:") &&
               !ts.startsWith("ar:") && !ts.startsWith("al:")) {
              lyrics[lyricCount].timeMs = parseLrcTime(ts);
              // Trim long lines
              if(text.length() > 38) text = text.substring(0, 36) + "..";
              lyrics[lyricCount].text   = text;
              lyricCount++;
            }
          }
        }
        pos = nl + 1;
      }
      Serial.printf("Lyrics loaded: %d lines\n", lyricCount);
    } else {
      Serial.println("No synced lyrics found");
    }
  }
  http.end();
}

// ── Find current lyric index ──────────────────
int findCurrentLyric(int progressMs) {
  if(lyricCount == 0) return -1;
  int idx = 0;
  for(int i = 0; i < lyricCount; i++) {
    if(lyrics[i].timeMs <= progressMs) idx = i;
    else break;
  }
  return idx;
}

// ── JPEG draw callback ────────────────────────
int jpegDraw(JPEGDRAW* pDraw) {
  // Draw into artSprite at offset
  for(int y = 0; y < pDraw->iHeight; y++) {
    for(int x = 0; x < pDraw->iWidth; x++) {
      artSprite.drawPixel(pDraw->x + x, pDraw->y + y,
                          pDraw->pPixels[y * pDraw->iWidth + x]);
    }
  }
  return 1;
}

// ── Fetch & decode album art ──────────────────
void fetchAlbumArt(String url) {
  if(url == "" || url == sp_prevArtUrl) return;
  sp_prevArtUrl = url;
  artLoaded = false;

  if(WiFi.status() != WL_CONNECTED) return;

  // Free old buffer
  if(artBuf) { free(artBuf); artBuf = nullptr; }

 HTTPClient http;
  http.begin(url);
  http.addHeader("User-Agent", "ESP32DeskClock/1.0");
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  int code = http.GET();
  Serial.printf("Art fetch: %s → %d\n", url.c_str(), code);

  if(code == 200) {
    artBufLen = http.getSize();
    if(artBufLen > 0 && artBufLen < 80000) {
      artBuf = (uint8_t*)malloc(artBufLen);
      if(artBuf) {
        WiFiClient* stream = http.getStreamPtr();
        stream->readBytes(artBuf, artBufLen);

        // Decode JPEG into 60x60 sprite
        artSprite.createSprite(60, 60);
        if(jpeg.openRAM(artBuf, artBufLen, jpegDraw)) {
          jpeg.decode(0, 0, JPEG_SCALE_QUARTER); // scale down to ~fit 60x60
          jpeg.close();
          artLoaded = true;
          Serial.println("Album art loaded!");
        }
      }
    }
  }
  http.end();
}

// ── Auth helpers ──────────────────────────────
String buildAuthURL() {
  return "https://accounts.spotify.com/authorize"
         "?client_id=" + String(clientId) +
         "&response_type=code"
         "&redirect_uri=" + String(redirectUri) +
         "&scope=user-read-playback-state%20user-modify-playback-state"
         "&show_dialog=true";
}

bool exchangeCode(String code) {
  HTTPClient http;
  http.begin("https://accounts.spotify.com/api/token");
  http.addHeader("Content-Type","application/x-www-form-urlencoded");
  String auth = base64::encode(String(clientId)+":"+String(clientSecret));
  http.addHeader("Authorization","Basic "+auth);
  String body = "grant_type=authorization_code&code="+code+
                "&redirect_uri="+String(redirectUri);
  int c = http.POST(body);
  if(c == 200) {
    DynamicJsonDocument doc(2048);
    deserializeJson(doc, http.getString());
    accessToken  = doc["access_token"].as<String>();
    refreshToken = doc["refresh_token"].as<String>();
    tokenExpiry  = millis()+(doc["expires_in"].as<int>()*1000);
    http.end(); return true;
  }
  http.end(); return false;
}

void refreshAccessToken() {
  if(refreshToken=="") return;
  HTTPClient http;
  http.begin("https://accounts.spotify.com/api/token");
  http.addHeader("Content-Type","application/x-www-form-urlencoded");
  String auth=base64::encode(String(clientId)+":"+String(clientSecret));
  http.addHeader("Authorization","Basic "+auth);
  int c=http.POST("grant_type=refresh_token&refresh_token="+refreshToken);
  if(c==200){
    DynamicJsonDocument doc(1024);
    deserializeJson(doc,http.getString());
    accessToken=doc["access_token"].as<String>();
    tokenExpiry=millis()+(doc["expires_in"].as<int>()*1000);
  }
  http.end();
}

void spotifyCommand(String ep, String method) {
  if(accessToken=="") return;
  if(millis()>tokenExpiry-60000) refreshAccessToken();
  HTTPClient http;
  http.begin("https://api.spotify.com/v1/me/player/"+ep);
  http.addHeader("Authorization","Bearer "+accessToken);
  if(method=="PUT"){
    http.addHeader("Content-Length","0");
    http.PUT("");
  } else {
    http.addHeader("Content-Length","0");
    http.POST("");
  }
  http.end();
}

// ── Fetch playback ────────────────────────────
void fetchPlayback() {
  if(accessToken=="") return;
  if(millis()>tokenExpiry-60000) refreshAccessToken();
  HTTPClient http;
  http.begin("https://api.spotify.com/v1/me/player");
  http.addHeader("Authorization","Bearer "+accessToken);
  int code=http.GET();
  if(code==200) {
    DynamicJsonDocument doc(8192);
    deserializeJson(doc,http.getString());
    sp_playing  = doc["is_playing"];
    sp_progress = doc["progress_ms"];
    sp_duration = doc["item"]["duration_ms"];
    sp_volume   = doc["device"]["volume_percent"];

    String newTrack  = doc["item"]["name"].as<String>();
    String newArtist = doc["item"]["artists"][0]["name"].as<String>();
    sp_album  = doc["item"]["album"]["name"].as<String>();

    // Get album art URL (pick smallest image)
    JsonArray images = doc["item"]["album"]["images"];
    if(images.size() > 0) {
      // Last image is usually smallest
      sp_artUrl = images[images.size()-1]["url"].as<String>();
    }

    // Track changed?
    if(newTrack != sp_track || newArtist != sp_artist) {
      sp_track  = newTrack;
      sp_artist = newArtist;
      // Fetch new lyrics and art
      fetchLyrics(sp_track, sp_artist);
      fetchAlbumArt(sp_artUrl);
    }

    // Trim display strings
    String dispTrack  = sp_track;
    String dispArtist = sp_artist;
    if(dispTrack.length()  > 20) dispTrack  = dispTrack.substring(0,18)+"..";
    if(dispArtist.length() > 20) dispArtist = dispArtist.substring(0,18)+"..";

  } else if(code==204) {
    sp_track="Nothing Playing";
    sp_artist="Open Spotify on phone";
    sp_playing=false;
  }
  http.end();
}

