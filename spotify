  tft.fillScreen(BG);
  tft.setTextDatum(MC_DATUM);
  tft.setTextColor(C_SPOTIFY,BG);
  tft.drawString("SPOTIFY SETUP",160,60,4);
  tft.setTextColor(C_WHITE,BG);
  tft.drawString("Open browser and go to:",160,100,2);
  tft.setTextColor(C_ACCENT,BG);
  tft.drawString("192.168.31.22",160,130,4);
