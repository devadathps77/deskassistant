    sprite.fillRect(8,34,60,60,tft.color565(20,40,30));
    sprite.drawRect(7,33,62,62,C_SPOTIFY);
    sprite.setTextColor(C_DIM,tft.color565(20,40,30));
    sprite.setTextDatum(MC_DATUM);
    sprite.drawString("ART",38,64,1);
  }

  // ── Track info (right of art) ─────────────
  String dispTrack  = sp_track;
  String dispArtist = sp_artist;
  String dispAlbum  = sp_album;
  if(dispTrack.length()  > 18) dispTrack  = dispTrack.substring(0,16)+"..";
  if(dispArtist.length() > 20) dispArtist = dispArtist.substring(0,18)+"..";
  if(dispAlbum.length()  > 20) dispAlbum  = dispAlbum.substring(0,18)+"..";

  sprite.setTextDatum(ML_DATUM);
  sprite.setTextColor(C_WHITE,  S_BG);
  sprite.drawString(dispTrack.c_str(),  76, 46, 2);
  sprite.setTextColor(C_SPOTIFY, S_BG);
  sprite.drawString(dispArtist.c_str(), 76, 66, 1);
  sprite.setTextColor(C_DIM,    S_BG);
  sprite.drawString(dispAlbum.c_str(),  76, 78, 1);

  // Playing indicator
  sprite.setTextDatum(ML_DATUM);
  sprite.setTextColor(sp_playing ? C_SPOTIFY : C_RED, S_BG);
  sprite.drawString(sp_playing ? ">> PLAYING" : "|| PAUSED", 76, 92, 1);

  // ── Progress bar ──────────────────────────
  int barX=8, barW=304, barY=100;
  int filled = sp_duration>0 ? (sp_progress*barW)/sp_duration : 0;
  sprite.fillRoundRect(barX,barY,barW,4,2,tft.color565(40,40,60));
  sprite.fillRoundRect(barX,barY,filled,4,2,C_SPOTIFY);

  // Time stamps
  char progStr[8], durStr[8];
  sprintf(progStr,"%d:%02d",(sp_progress/1000)/60,(sp_progress/1000)%60);
  sprintf(durStr, "%d:%02d",(sp_duration/1000)/60,(sp_duration/1000)%60);
  sprite.setTextDatum(ML_DATUM);
  sprite.setTextColor(C_DIM,S_BG);
  sprite.drawString(progStr,barX,barY+10,1);
  sprite.setTextDatum(MR_DATUM);
  sprite.drawString(durStr,barX+barW,barY+10,1);

  sprite.drawFastHLine(0,118,320,tft.color565(30,30,50));

  // ── Lyrics section ────────────────────────
  if(lyricCount > 0 && sp_playing) {
    currentLyric = findCurrentLyric(sp_progress);

    // Show 4 lines: prev-prev, prev, CURRENT, next
    struct { int idx; int y; uint16_t color; int font; } lines[] = {
      { currentLyric-2, 130, C_LYRIC_DIM,  1 },
      { currentLyric-1, 148, C_DIM,        1 },
      { currentLyric,   168, C_SPOTIFY,    2 }, // current — bright green, bigger
      { currentLyric+1, 186, C_DIM,        1 },
    };

    for(auto& l : lines) {
      if(l.idx >= 0 && l.idx < lyricCount) {
        sprite.setTextDatum(MC_DATUM);
        sprite.setTextColor(l.color, S_BG);
        sprite.drawString(lyrics[l.idx].text.c_str(), 160, l.y, l.font);
      }
    }

    // Lyric progress indicator
    if(currentLyric+1 < lyricCount) {
      int nextMs  = lyrics[currentLyric+1].timeMs;
      int currMs  = lyrics[currentLyric].timeMs;
      int spanMs  = nextMs - currMs;
      int elapsed = sp_progress - currMs;
      if(spanMs > 0) {
        int lyrW = 200;
        int lyrX = 60;
        int lyrFill = constrain((elapsed*lyrW)/spanMs, 0, lyrW);
        sprite.fillRoundRect(lyrX,200,lyrW,2,1,tft.color565(30,30,50));
        sprite.fillRoundRect(lyrX,200,lyrFill,2,1,C_LYRIC_DIM);
      }
    }

  } else if(lyricCount == 0) {
    sprite.setTextDatum(MC_DATUM);
    sprite.setTextColor(C_DIM,S_BG);
    sprite.drawString("No lyrics available",160,160,1);
    sprite.drawString("SHORT=Play/Pause",160,180,1);
    sprite.drawString("DOUBLE=Next  LONG=Prev",160,196,1);
  } else {
    // Paused — show controls hint
    sprite.setTextDatum(MC_DATUM);
    sprite.setTextColor(C_DIM,S_BG);
    sprite.drawString("|| PAUSED",160,155,2);
    sprite.drawString("SHORT=Play/Pause",160,180,1);
    sprite.drawString("DOUBLE=Next  LONG=Prev",160,196,1);
  }

  // ── Volume bar ────────────────────────────
  sprite.drawFastHLine(0,208,320,tft.color565(30,30,50));
  char volStr[12];
  sprintf(volStr,"VOL %d%%",sp_volume);
  sprite.setTextColor(C_DIM,S_BG);
  sprite.setTextDatum(ML_DATUM);
  sprite.drawString(volStr,8,220,1);
  // Volume bar
  sprite.fillRoundRect(60,216,200,4,2,tft.color565(40,40,60));
  sprite.fillRoundRect(60,216,(sp_volume*200)/100,4,2,C_SPOTIFY);

  sprite.pushSprite(0,0);
}

// ── Web server handlers ───────────────────────
void handleRoot() {
  String html = "<html><body style='background:#000;color:#1DB954;"
                "font-family:sans-serif;text-align:center;padding:50px'>"
                "<h1>ESP32 Spotify Remote</h1>"
                "<a href='" + buildAuthURL() + "' style='background:#1DB954;"
                "color:#000;padding:15px 30px;border-radius:25px;"
                "text-decoration:none;font-size:18px'>Connect Spotify</a>"
                "</body></html>";
  server.send(200,"text/html",html);
}

void handleCallback() {
  if(server.hasArg("code")) {
    String code=server.arg("code");
    showSplash("Authorizing...","Please wait");
    if(exchangeCode(code)) {
      server.send(200,"text/html",
        "<html><body style='background:#000;color:#1DB954;"
        "font-family:sans-serif;text-align:center;padding:50px'>"
        "<h1>Connected!</h1><p>Return to your ESP32.</p></body></html>");
      showSplash("Connected!","Loading...");
      delay(1000);
    } else {
      server.send(400,"text/plain","Auth failed");
    }
  }
}

