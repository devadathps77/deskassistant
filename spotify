  Serial.println("Ready - go to http://192.168.31.22");
}

// ── Button handling ───────────────────────────
unsigned long btnPressTime  = 0;
bool          btnPressed    = false;
unsigned long lastBtnRelease= 0;
int           clickCount    = 0;
#define LONG_PRESS  800
#define DOUBLE_TIME 400

void handleButton() {
  bool btn=digitalRead(21);
  if(btn==LOW && !btnPressed){
    btnPressed=true;
    btnPressTime=millis();
  }
  if(btn==HIGH && btnPressed){
    btnPressed=false;
    unsigned long dur=millis()-btnPressTime;
    if(dur>LONG_PRESS){
      spotifyCommand("previous","POST");
      Serial.println("Prev");
    } else {
      clickCount++;
      lastBtnRelease=millis();
    }
  }
  if(clickCount>0 && millis()-lastBtnRelease>DOUBLE_TIME){
    if(clickCount>=2){
      spotifyCommand("next","POST");
      Serial.println("Next");
    } else {
      if(sp_playing) spotifyCommand("pause","PUT");
      else           spotifyCommand("play","PUT");
      Serial.println("Play/Pause");
    }
    clickCount=0;
  }
}

// ── Loop ──────────────────────────────────────
void loop() {
  server.handleClient();
  handleButton();

  if(accessToken!="" && millis()-lastSpotifyFetch>SPOTIFY_INTERVAL){
    lastSpotifyFetch=millis();
    fetchPlayback();
    drawSpotify();
  }

  delay(20);
}
